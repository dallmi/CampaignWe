// ============================================================================
// CampaignWe Query - Flatten click_event data for gwm-prompt-library.aspx
// ============================================================================
// Purpose: Extract and flatten click_event data from Application Insights
//          customEvents table for gwm-prompt-library.aspx page.
//
// Data Structure:
//   Top-level columns: timestamp, name, user_Id, session_Id, client_CountryOrRegion
//   customDimensions:  Contains ONE key: "CustomProps" (JSON string)
//   CustomProps keys:  SiteID, SiteName, PageId, PageName, PageURL, PageStatus,
//                      ComponentName, ContentOwner, ContentType, Email, GPN,
//                      FileName_Label, FileType_Label, Link_Type, Link_address,
//                      Link_ancestors, Link_label, NewsCategory, PublishingDate
//
// Output: All CustomProps keys become columns with CP_ prefix.
//
// HOW TO USE: Copy from "set truncationmaxrecords" to "order by"
//
// NOTE: 'timestamp [UTC]' is formatted as 'dd/MM/yyyy HH:mm:ss.fffffff' to preserve
//       millisecond precision for CSV export (Excel truncates the native format).
// ============================================================================


// === COPY FROM HERE ===
set truncationmaxrecords = 500000;
let TimeRange = 90d;
let CustomPropsPrefix = "CP_";
let ClickData = customEvents
    | where timestamp >= ago(TimeRange)
    | where name == 'click_event'
    | extend cd = todynamic(customDimensions)
    // --- customDimensions has ONE key: CustomProps (JSON string with all fields) ---
    | extend CustomPropsRaw = tostring(cd.CustomProps)
    | extend CP = iff(isnotempty(CustomPropsRaw) and CustomPropsRaw startswith "{", todynamic(CustomPropsRaw), dynamic({}))
    | where tostring(CP.PageURL) contains 'gwm-prompt-library'
    | serialize
    | extend rowId = row_number()
    // --- Expand CustomProps keys (flat key-value pairs) ---
    | extend cpKeys = bag_keys(CP)
    | extend cpKeys = iff(array_length(cpKeys) == 0, dynamic(["__no_cp__"]), cpKeys)
    | mv-expand cpKey = cpKeys to typeof(string)
    | extend cpValue = tostring(CP[cpKey])
    // --- Build flattened key-value pairs with CP_ prefix ---
    | extend kvBag = iff(cpKey == "__no_cp__", dynamic({}), pack(strcat(CustomPropsPrefix, cpKey), cpValue))
    // --- Reaggregate back to one row per event ---
    | summarize take_any(timestamp), take_any(name), take_any(client_CountryOrRegion), take_any(user_Id), take_any(session_Id), merged = make_bag(kvBag) by rowId
    | extend finalBag = coalesce(merged, dynamic({}));
ClickData
| evaluate bag_unpack(finalBag)
| project-away rowId, merged
| extend ['timestamp [UTC]'] = format_datetime(timestamp, 'dd/MM/yyyy HH:mm:ss.fffffff')
| project-away timestamp
| project-reorder ['timestamp [UTC]'], name, client_CountryOrRegion, user_Id, session_Id
| order by ['timestamp [UTC]'] desc
// === COPY TO HERE ===


// ============================================================================
// ALTERNATIVE QUERIES (copy/paste separately)
// ============================================================================

// --- QUERY A: Key discovery - find all unique CustomProps keys ---
// customEvents | where timestamp >= ago(30d) | where name == 'click_event' | extend cd = todynamic(customDimensions) | extend CP = todynamic(tostring(cd.CustomProps)) | where tostring(CP.PageURL) contains 'gwm-prompt-library' | extend cpKeys = bag_keys(CP) | mv-expand cpKey = cpKeys to typeof(string) | summarize KeyCount = count(), SampleValue = take_any(tostring(CP[cpKey])) by Key = cpKey | order by KeyCount desc

// --- QUERY B: Simplified version (no CP_ prefix, just unpack CustomProps) ---
// customEvents | where timestamp >= ago(30d) | where name == 'click_event' | extend cd = todynamic(customDimensions) | extend CP = todynamic(tostring(cd.CustomProps)) | where tostring(CP.PageURL) contains 'gwm-prompt-library' | evaluate bag_unpack(CP) | project-reorder timestamp, name | order by timestamp desc


// --- QUERY C: Anonymized export (hash GPN, exclude Email) ---
// Use this query when department data is available in Application Insights
// and the HR join in the Python pipeline is no longer needed.
// GPN is hashed with SHA-256 at query level so it never leaves App Insights in plain text.
// Email is excluded entirely.
set truncationmaxrecords = 500000;
let TimeRange = 90d;
let CustomPropsPrefix = "CP_";
let ClickData = customEvents
    | where timestamp >= ago(TimeRange)
    | where name == 'click_event'
    | extend cd = todynamic(customDimensions)
    | extend CustomPropsRaw = tostring(cd.CustomProps)
    | extend CP = iff(isnotempty(CustomPropsRaw) and CustomPropsRaw startswith "{", todynamic(CustomPropsRaw), dynamic({}))
    | where tostring(CP.PageURL) contains 'gwm-prompt-library'
    | serialize
    | extend rowId = row_number()
    // --- Expand CustomProps keys (flat key-value pairs) ---
    | extend cpKeys = bag_keys(CP)
    | extend cpKeys = iff(array_length(cpKeys) == 0, dynamic(["__no_cp__"]), cpKeys)
    | mv-expand cpKey = cpKeys to typeof(string)
    // --- Hash GPN, drop Email, pass through everything else ---
    | where cpKey != "Email"
    | extend cpValue = iff(cpKey == "GPN", hash_sha256(tostring(CP[cpKey])), tostring(CP[cpKey]))
    // --- Build flattened key-value pairs with CP_ prefix ---
    | extend kvBag = iff(cpKey == "__no_cp__", dynamic({}), pack(strcat(CustomPropsPrefix, cpKey), cpValue))
    // --- Reaggregate back to one row per event ---
    | summarize take_any(timestamp), take_any(name), take_any(client_CountryOrRegion), take_any(user_Id), take_any(session_Id), merged = make_bag(kvBag) by rowId
    | extend finalBag = coalesce(merged, dynamic({}));
ClickData
| evaluate bag_unpack(finalBag)
| project-away rowId, merged
| extend ['timestamp [UTC]'] = format_datetime(timestamp, 'dd/MM/yyyy HH:mm:ss.fffffff')
| project-away timestamp
| project-reorder ['timestamp [UTC]'], name, client_CountryOrRegion, user_Id, session_Id
| order by ['timestamp [UTC]'] desc


// --- QUERY F: Anonymized export - all events, all pages (click + search combined) ---
// Extends Query C to cover ALL event types (click_event, SEARCH_TRIGGERED, etc.)
// and ALL intranet pages (no PageURL filter).
//
// Uses 4-level nesting logic (from SearchAnalytics) to handle both:
//   - click_event: flat CustomProps (L2 only)
//   - search events: deeply nested CustomProps (L2 → L3 → L4)
//
// Anonymization applied at every nesting level:
//   - Email key is dropped (L2, L3, L4)
//   - GPN key is SHA-256 hashed (L2, L3, L4)
//   - mainBag (non-CustomProps customDimensions keys) is passed through as-is
set truncationmaxrecords = 500000;
let TimeRange = 90d;
let CustomPropsPrefix = "CP_";
let AllData = customEvents
    | where timestamp >= ago(TimeRange)
    | extend cd = todynamic(customDimensions)
    | serialize
    | extend rowId = row_number()
    // --- Level 1: Separate CustomProps from other customDimensions keys ---
    | extend CustomPropsRaw = tostring(cd.CustomProps)
    | extend CP = iff(isnotempty(CustomPropsRaw) and CustomPropsRaw startswith "{", todynamic(CustomPropsRaw), dynamic({}))
    | extend mainBag = bag_remove_keys(cd, dynamic(["CustomProps"]))
    // --- Level 2: Expand CustomProps keys; drop Email, hash GPN ---
    | extend cpKeys = bag_keys(CP)
    | extend cpKeys = iff(array_length(cpKeys) == 0, dynamic(["__no_cp__"]), cpKeys)
    | mv-expand cpKey = cpKeys to typeof(string)
    | where cpKey != "Email"
    | extend cpValue = iff(cpKey == "GPN", hash_sha256(tostring(CP[cpKey])), tostring(CP[cpKey]))
    // --- Level 3: Check if CP values contain nested JSON objects ---
    | extend isNestedL3 = cpKey != "__no_cp__" and isnotempty(cpValue) and cpValue startswith "{"
    | extend L3Bag = iff(isNestedL3, coalesce(todynamic(cpValue), dynamic({})), dynamic({}))
    | extend subKeys = bag_keys(L3Bag)
    | extend subKeys = iff(array_length(subKeys) == 0, dynamic(["__no_sub__"]), subKeys)
    | mv-expand subKey = subKeys to typeof(string)
    | where not(isNestedL3 and subKey == "Email")
    | extend subValue = iff(
        subKey != "__no_sub__",
        iff(subKey == "GPN", hash_sha256(tostring(L3Bag[subKey])), tostring(L3Bag[subKey])),
        "")
    // --- Level 4: Check if Level 3 values contain nested JSON objects ---
    | extend isNestedL4 = subKey != "__no_sub__" and isnotempty(subValue) and subValue startswith "{"
    | extend L4Bag = iff(isNestedL4, coalesce(todynamic(subValue), dynamic({})), dynamic({}))
    | extend subSubKeys = bag_keys(L4Bag)
    | extend subSubKeys = iff(array_length(subSubKeys) == 0, dynamic(["__no_subsub__"]), subSubKeys)
    | mv-expand subSubKey = subSubKeys to typeof(string)
    | where not(isNestedL4 and subSubKey == "Email")
    // --- Build flattened key-value pairs ---
    // Flat L2 value:    CP_key          → value
    // Nested L3 value:  CP_key_subKey   → value
    // Nested L4 value:  CP_key_sub_sub  → value
    | extend kvBag = case(
        cpKey == "__no_cp__", dynamic({}),
        not(isNestedL3), pack(strcat(CustomPropsPrefix, cpKey), cpValue),
        subKey == "__no_sub__", pack(strcat(CustomPropsPrefix, cpKey), cpValue),
        not(isNestedL4), pack(strcat(CustomPropsPrefix, cpKey, "_", subKey), subValue),
        subSubKey == "__no_subsub__", pack(strcat(CustomPropsPrefix, cpKey, "_", subKey), subValue),
        pack(strcat(CustomPropsPrefix, cpKey, "_", subKey, "_", subSubKey),
             iff(subSubKey == "GPN", hash_sha256(tostring(L4Bag[subSubKey])), tostring(L4Bag[subSubKey])))
      )
    // --- Reaggregate back to one row per event ---
    | summarize take_any(timestamp), take_any(name), take_any(client_CountryOrRegion), take_any(user_Id), take_any(session_Id), take_any(mainBag), merged = make_bag(kvBag) by rowId
    | extend finalBag = bag_merge(mainBag, coalesce(merged, dynamic({})));
AllData
| evaluate bag_unpack(finalBag)
| project-away rowId, mainBag, merged
| extend ['timestamp [UTC]'] = format_datetime(timestamp, 'dd/MM/yyyy HH:mm:ss.fffffff')
| project-away timestamp
| project-reorder ['timestamp [UTC]'], name, client_CountryOrRegion, user_Id, session_Id
| order by ['timestamp [UTC]'] desc


// --- QUERY G: Query F filtered to SEARCH events only ---
// Same anonymized 4-level flattening as Query F, but restricted to events
// where name starts with "SEARCH" (e.g. SEARCH_TRIGGERED, SEARCH_RESULT_CLICK).
// Use this to inspect how search data comes through the combined pipeline.
set truncationmaxrecords = 500000;
let TimeRange = 90d;
let CustomPropsPrefix = "CP_";
let AllData = customEvents
    | where timestamp >= ago(TimeRange)
    | where name startswith "SEARCH"
    | extend cd = todynamic(customDimensions)
    | serialize
    | extend rowId = row_number()
    | extend CustomPropsRaw = tostring(cd.CustomProps)
    | extend CP = iff(isnotempty(CustomPropsRaw) and CustomPropsRaw startswith "{", todynamic(CustomPropsRaw), dynamic({}))
    | extend mainBag = bag_remove_keys(cd, dynamic(["CustomProps"]))
    | extend cpKeys = bag_keys(CP)
    | extend cpKeys = iff(array_length(cpKeys) == 0, dynamic(["__no_cp__"]), cpKeys)
    | mv-expand cpKey = cpKeys to typeof(string)
    | where cpKey != "Email"
    | extend cpValue = iff(cpKey == "GPN", hash_sha256(tostring(CP[cpKey])), tostring(CP[cpKey]))
    | extend isNestedL3 = cpKey != "__no_cp__" and isnotempty(cpValue) and cpValue startswith "{"
    | extend L3Bag = iff(isNestedL3, coalesce(todynamic(cpValue), dynamic({})), dynamic({}))
    | extend subKeys = bag_keys(L3Bag)
    | extend subKeys = iff(array_length(subKeys) == 0, dynamic(["__no_sub__"]), subKeys)
    | mv-expand subKey = subKeys to typeof(string)
    | where not(isNestedL3 and subKey == "Email")
    | extend subValue = iff(
        subKey != "__no_sub__",
        iff(subKey == "GPN", hash_sha256(tostring(L3Bag[subKey])), tostring(L3Bag[subKey])),
        "")
    | extend isNestedL4 = subKey != "__no_sub__" and isnotempty(subValue) and subValue startswith "{"
    | extend L4Bag = iff(isNestedL4, coalesce(todynamic(subValue), dynamic({})), dynamic({}))
    | extend subSubKeys = bag_keys(L4Bag)
    | extend subSubKeys = iff(array_length(subSubKeys) == 0, dynamic(["__no_subsub__"]), subSubKeys)
    | mv-expand subSubKey = subSubKeys to typeof(string)
    | where not(isNestedL4 and subSubKey == "Email")
    | extend kvBag = case(
        cpKey == "__no_cp__", dynamic({}),
        not(isNestedL3), pack(strcat(CustomPropsPrefix, cpKey), cpValue),
        subKey == "__no_sub__", pack(strcat(CustomPropsPrefix, cpKey), cpValue),
        not(isNestedL4), pack(strcat(CustomPropsPrefix, cpKey, "_", subKey), subValue),
        subSubKey == "__no_subsub__", pack(strcat(CustomPropsPrefix, cpKey, "_", subKey), subValue),
        pack(strcat(CustomPropsPrefix, cpKey, "_", subKey, "_", subSubKey),
             iff(subSubKey == "GPN", hash_sha256(tostring(L4Bag[subSubKey])), tostring(L4Bag[subSubKey])))
      )
    | summarize take_any(timestamp), take_any(name), take_any(client_CountryOrRegion), take_any(user_Id), take_any(session_Id), take_any(mainBag), merged = make_bag(kvBag) by rowId
    | extend finalBag = bag_merge(mainBag, coalesce(merged, dynamic({})));
AllData
| evaluate bag_unpack(finalBag)
| project-away rowId, mainBag, merged
| extend ['timestamp [UTC]'] = format_datetime(timestamp, 'dd/MM/yyyy HH:mm:ss.fffffff')
| project-away timestamp
| project-reorder ['timestamp [UTC]'], name, client_CountryOrRegion, user_Id, session_Id
| order by ['timestamp [UTC]'] desc


// --- QUERY H: Truly anonymized SEARCH summary using HyperLogLog (HLL) ---
// Unlike Query G (SHA-256 pseudonymization, still reversible via brute force),
// this query produces AGGREGATE rows with HLL-estimated distinct user/session
// counts — no individual event rows exist in the output.
//
// Why this is truly anonymous (not pseudonymous):
//   - No GPN, no Email — both absent entirely
//   - No individual rows: data is grouped by time bucket + search dimensions
//   - user_Id and session_Id are replaced by HLL-estimated distinct counts
//     (HLL has ~1-2% error margin, adding inherent noise on top)
//   - A group row cannot be traced back to any individual
//
// Output format change vs Query G:
//   Query G: one row per event (pseudonymized)
//   Query H: one row per (day, event type, search dimensions) + estimated counts
//
// NOTE: queryText may itself contain personal data if users searched for names.
//       Consider suppressing or generalising it if that is a concern.
let TimeRange = 90d;
customEvents
| where timestamp >= ago(TimeRange)
| where name startswith "SEARCH"
| extend cd = todynamic(customDimensions)
| extend CustomPropsRaw = tostring(cd.CustomProps)
| extend CP = iff(isnotempty(CustomPropsRaw) and CustomPropsRaw startswith "{", todynamic(CustomPropsRaw), dynamic({}))
// --- Extract search dimensions (no GPN, no Email) ---
| extend
    deviceType    = tostring(CP.deviceType),
    // queryText appears flat on SEARCH_TRIGGERED, nested inside searchQuery on other events
    queryText     = coalesce(
                        tostring(todynamic(tostring(CP.searchQuery)).queryText),
                        tostring(CP.queryText)),
    queryLanguage = tostring(todynamic(tostring(CP.searchQuery)).queryLanguage),
    searchLatency = tostring(todynamic(tostring(CP.searchPerformance)).searchLatency),
    clickedTAB    = tostring(todynamic(tostring(CP.searchResultsInteraction)).clickedTAB),
    appliedFilter = tostring(todynamic(tostring(CP.searchResultsInteraction)).appliedFilter)
// --- Aggregate into HLL sketches per day + dimension combination ---
| summarize
    EventCount   = count(),
    UserHLL      = hll(user_Id),
    SessionHLL   = hll(session_Id)
    by
    ['date [UTC]']         = bin(timestamp, 1d),
    name,
    client_CountryOrRegion,
    deviceType,
    queryText,
    queryLanguage,
    searchLatency,
    clickedTAB,
    appliedFilter
// --- Decode HLL sketches into estimated distinct counts, then discard raw sketches ---
| extend
    EstimatedDistinctUsers    = dcount_hll(UserHLL),
    EstimatedDistinctSessions = dcount_hll(SessionHLL)
| project-away UserHLL, SessionHLL
| extend ['date [UTC]'] = format_datetime(['date [UTC]'], 'dd/MM/yyyy')
| project-reorder ['date [UTC]'], name, client_CountryOrRegion, deviceType, queryText, queryLanguage, EventCount, EstimatedDistinctUsers, EstimatedDistinctSessions
| order by ['date [UTC]'] desc


// --- QUERY E: Distinct hashed GPNs vs user_Ids (30 days) ---
// Compares how many unique identifiers exist via each method.
// Helps assess whether GPN-based hashing covers more or fewer users than App Insights user_Id.
customEvents
| where timestamp >= ago(30d)
| where name == 'click_event'
| extend cd = todynamic(customDimensions)
| extend CP = todynamic(tostring(cd.CustomProps))
| where tostring(CP.PageURL) contains 'gwm-prompt-library'
| extend GPN = tostring(CP.GPN)
| extend HashedGPN = iff(isnotempty(GPN), hash_sha256(GPN), "")
| summarize
    TotalEvents = count(),
    DistinctHashedGPNs = dcountif(HashedGPN, isnotempty(HashedGPN)),
    DistinctUserIds = dcount(user_Id),
    EventsWithGPN = countif(isnotempty(GPN)),
    EventsWithoutGPN = countif(isempty(GPN))


// --- QUERY D: Filter by specific email (change EmailFilter value) ---
set truncationmaxrecords = 500000;
let TimeRange = 90d;
let EmailFilter = "john.doe";
let CustomPropsPrefix = "CP_";
let ClickData = customEvents
    | where timestamp >= ago(TimeRange)
    | where name == 'click_event'
    | extend cd = todynamic(customDimensions)
    | extend CustomPropsRaw = tostring(cd.CustomProps)
    | extend CP = iff(isnotempty(CustomPropsRaw) and CustomPropsRaw startswith "{", todynamic(CustomPropsRaw), dynamic({}))
    | where tostring(CP.PageURL) contains 'gwm-prompt-library'
    | where tostring(CP.Email) contains EmailFilter
    | serialize
    | extend rowId = row_number()
    | extend cpKeys = bag_keys(CP)
    | extend cpKeys = iff(array_length(cpKeys) == 0, dynamic(["__no_cp__"]), cpKeys)
    | mv-expand cpKey = cpKeys to typeof(string)
    | extend cpValue = tostring(CP[cpKey])
    | extend kvBag = iff(cpKey == "__no_cp__", dynamic({}), pack(strcat(CustomPropsPrefix, cpKey), cpValue))
    | summarize take_any(timestamp), take_any(name), take_any(client_CountryOrRegion), take_any(user_Id), take_any(session_Id), merged = make_bag(kvBag) by rowId
    | extend finalBag = coalesce(merged, dynamic({}));
ClickData
| evaluate bag_unpack(finalBag)
| project-away rowId, merged
| extend ['timestamp [UTC]'] = format_datetime(timestamp, 'dd/MM/yyyy HH:mm:ss.fffffff')
| project-away timestamp
| project-reorder ['timestamp [UTC]'], name, client_CountryOrRegion, user_Id, session_Id
| order by ['timestamp [UTC]'] desc
